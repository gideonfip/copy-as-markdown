{
	"manifest_version": 3,
	"name": "Copy as Markdown",
	"homepage_url": "https://github.com/",
	"version": "1.0.0",
	"description": "Copy any web page to your clipboard to give your LLMs full context. Forked from Obsidian Web Clipper extension.",
	"permissions": [
		"activeTab",
		"clipboardWrite",
		"contextMenus",
		"storage",
		"scripting"
	],
	"host_permissions": [
		"<all_urls>",
		"http://*/*",
		"https://*/*"
	],
	"action": {
		"default_popup": "popup.html",
		"default_icon": {
			"16": "icons/copy.png",
			"48": "icons/copy.svg",
			"128": "icons/copy.svg"
		}
	},
	"options_ui": {
		"page": "settings.html"
	},
	"icons": {
		"16": "icons/copy.png",
		"48": "icons/copy.svg",
		"128": "icons/copy.svg"
	},
	"background": {
		"service_worker": "background.js"
	},
	"content_scripts": [
		{
			"matches": [
				"http://*/*",
				"https://*/*"
			],
			"js": [
				"browser-polyfill.min.js",
				"content.js"
			],
			"css": [
				"highlighter.css"
			]
		}
	],
	"web_accessible_resources": [
		{
			"resources": [
				"reader.css",
				"reader-script.js",
				"browser-polyfill.min.js",
				"style.css",
				"side-panel.html",
				"flatten-shadow-dom.js"
			],
			"extension_ids": [
				"*"
			],
			"matches": [
				"*://*/*"
			]
		}
	],
	"content_security_policy": {
		"extension_pages": "script-src 'self'; object-src 'self'"
	},
	"commands": {
		"_execute_action": {
			"suggested_key": {
				"default": "Ctrl+Shift+O",
				"mac": "Command+Shift+O"
			},
			"description": "Open Obsidian Clipper"
		},
		"quick_clip": {
			"suggested_key": {
				"default": "Alt+Shift+O",
				"mac": "Alt+Shift+O"
			},
			"description": "Quick clip"
		},
		"toggle_highlighter": {
			"suggested_key": {
				"default": "Alt+Shift+H",
				"mac": "Alt+Shift+H"
			},
			"description": "Toggle highlighter mode"
		},
		"toggle_reader": {
			"suggested_key": {
				"default": "Alt+Shift+R",
				"mac": "Alt+Shift+R"
			},
			"description": "Toggle reader mode"
		},
		"copy_to_clipboard": {
			"suggested_key": {
				"default": "Ctrl+Shift+C",
				"mac": "Command+Shift+C"
			},
			"description": "__MSG_commandCopyToClipboard__"
		}
	}
}
